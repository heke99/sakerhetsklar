# ============================================================
# Säkerhetsklar — environment configuration
# Copy to .env.local for development. Never commit real secrets.
# ============================================================

# --- Required (core) ---------------------------------------

# Supabase project URL (safe to expose to the client).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (safe to expose to the client).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. SERVER ONLY — bypasses RLS. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by migrations, seeds and DB tests.
# Example: postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_DB_URL=

# Public base URL of the app (used for links in invitations/password reset).
# Example: https://app.sakerhetsklar.se
APP_BASE_URL=http://localhost:3000

# Comma-separated hosts served by the shared (Model A) plane.
APP_PRIMARY_HOSTS=localhost:3000

# Shared secret required by scheduled job endpoints (/api/v1/jobs/*).
# Jobs fail closed (401) when unset or mismatched.
JOB_RUNNER_SECRET=

# Secret used to HMAC-sign outbound webhooks.
WEBHOOK_SIGNING_SECRET=

# --- Optional integrations (features fail closed / are skipped when unset) ---

# Resend API key for transactional email (invitations, password reset,
# deadline notifications). When unset, email delivery is disabled and the UI
# falls back to copyable links for admins.
RESEND_API_KEY=

# From-address for outbound email. Example: "Säkerhetsklar <no-reply@sakerhetsklar.se>"
EMAIL_FROM=

# Microsoft Teams incoming webhook for platform-level operational alerts.
# (Per-tenant Teams webhooks are configured via secret refs in the database.)
TEAMS_WEBHOOK_URL=

# Sentry DSN for error tracking. When unset, error tracking is disabled.
SENTRY_DSN=

# Supabase storage bucket for evidence files (default: evidence).
SUPABASE_STORAGE_BUCKET=evidence

# --- Deployment models B/C (per-tenant data planes) ---------
# tenant_data_plane_connections rows store *references* to env var names
# (never the secrets themselves). For each configured connection, define the
# referenced variables here, e.g.:
# DATA_PLANE_ACME_SERVICE_ROLE_KEY=
# DATA_PLANE_ACME_DB_URL=

# --- Not yet used (reserved for planned integrations) -------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER_URL=
# SAML_METADATA_URL=
